# Expo public client configuration
# Use the project URL origin, for example https://example.supabase.co.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Optional public Edge Function or backend URL that refreshes current promotion recommendations.
EXPO_PUBLIC_PROMOTION_REFRESH_URL=
# Optional public Edge Function or backend URL that refreshes current prediction candidates.
EXPO_PUBLIC_PREDICTION_REFRESH_URL=
# Optional override for first-two-races odds requests. Defaults to
# EXPO_PUBLIC_SUPABASE_URL/functions/v1/request-track-race-odds when omitted.
EXPO_PUBLIC_TRACK_ODDS_REQUEST_URL=

# Server-side only. Do not expose these in the Expo client.
# Preferred custom name for Supabase Edge Function secrets because SUPABASE_* names are reserved by Supabase.
FEELING_GAMBA_SUPABASE_SECRET_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional server-side token for force-refresh calls to refresh-current-promotions.
PROMOTION_REFRESH_ADMIN_TOKEN=
# Optional server-side token for force-refresh calls to refresh-current-predictions.
PREDICTION_REFRESH_ADMIN_TOKEN=
# Required server-side token for hosted refresh-race-days-and-insights writes.
RACE_DAY_REFRESH_ADMIN_TOKEN=
